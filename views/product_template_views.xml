<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_headless" model="ir.ui.view">
        <field name="name">product.template.form.headless</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Headless CMS &amp; SEO" name="headless_data">
                    <group>
                        <group string="SEO &amp; URL">
                            <field name="headless_slug" placeholder="ej: silla-moderna-madera"/>
                            <field name="headless_seo_keyword"/>
                            <field name="headless_meta_title"/>
                            <field name="headless_meta_description"/>
                        </group>

                        <group string="Especificaciones Físicas">
                            <label for="dim_length" string="Dimensiones (L x A x A)"/>
                            <div class="o_row">
                                <field name="dim_length" placeholder="Largo"/> x
                                <field name="dim_width" placeholder="Ancho"/> x
                                <field name="dim_height" placeholder="Alto"/> cm
                            </div>
                            <field name="weight" string="Peso (kg)"/>
                            <field name="volume" string="Volumen (m³)"/>
                            <field name="headless_material"/>
                        </group>
                    </group>

                    <separator string="Galería Adicional (API)"/>
                    <group col="4">
                        <field name="headless_image_1" widget="image" options="{'size': [150, 150]}"/>
                        <field name="headless_image_2" widget="image" options="{'size': [150, 150]}"/>
                        <field name="headless_image_3" widget="image" options="{'size': [150, 150]}"/>
                        <field name="headless_image_4" widget="image" options="{'size': [150, 150]}"/>
                    </group>

                    <separator string="Video del Producto (API)"/>
                    <group>
                        <group string="Video subido a Odoo">
                            <field name="headless_video_filename" invisible="1"/>

                            <field name="headless_video_file"
                                   widget="binary"
                                   filename="headless_video_filename"
                                   string="Subir Video"
                                   options="{'accepted_file_extensions': '.mp4,.webm,.mov'}"/>

                            <field name="headless_video_poster"
                                   widget="image"
                                   string="Poster / Portada"
                                   options="{'size': [220, 160]}"/>
                        </group>

                        <group string="Video externo opcional">
                            <field name="headless_video_url_manual"
                                   placeholder="https://..."/>

                            <div class="alert alert-info" role="alert" colspan="2">
                                <strong>Prioridad de reproducción:</strong>
                                <ol>
                                    <li>Si subes un archivo de video, la API usará el archivo subido en Odoo.</li>
                                    <li>Si no subes archivo, la API usará la URL externa.</li>
                                    <li>Para reproducción directa en HTML5, se recomienda MP4 o WebM.</li>
                                </ol>
                            </div>
                        </group>
                    </group>

                    <separator string="Descripciones"/>
                    <group>
                        <field name="headless_short_description" placeholder="Resumen corto..."/>
                    </group>

                    <field name="headless_long_description" placeholder="Descripción detallada..."/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>